<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Carbon Credit | Green Score Quiz</title>
  <link rel="stylesheet" href="quiz.css" />
</head>

<body>
  <main class="quiz-shell">
    <header class="quiz-header">
      <a class="brand" href="index.html" aria-label="My Carbon Credit home">
        <img class="quiz-full-logo" src="assets/my-carbon-credit-logo.svg" alt="My Carbon Credit" />
      </a>
      <div class="header-actions">
        <div class="wallet-pill" id="walletPill" aria-label="Green points wallet">
          <span class="wallet-icon" aria-hidden="true">🌱</span>
          <strong id="walletPoints">0</strong>
          <span>Green Points</span>
        </div>
        <div class="login-button" id="loginButton" style="display:inline-flex; align-items:center; justify-content:center; cursor:default; pointer-events:none; padding: 0 24px;">Welcome User</div>
      </div>
    </header>

    <section class="landing-screen" id="landingScreen">
      <div class="landing-hero">
        <div class="landing-copy">
          <p class="section-kicker">Green Score Challenge</p>
          <h1>Turn your daily choices into a carbon score adventure.</h1>
          <p>
            Play through lifestyle, mobility, home energy, food, digital habits, and workplace ESG missions.
            Unlock badges after every section and finish with a personal footprint score.
          </p>
          <div class="landing-actions">
            <button class="nav-button next-button" id="startQuizButton" type="button">Lets Play →</button>
            <a class="nav-button back-button" href="index.html">View main site</a>
          </div>
        </div>
        <div class="mission-board" aria-label="Quiz rewards preview">
          <div class="score-preview earning-preview">
            <div class="wallet-hero-art" aria-hidden="true">
              <div class="wallet-graphic">
                <span class="wallet-slot"></span>
                <span class="coin coin-one">🌳</span>
                <span class="coin coin-two">🌳</span>
                <span class="coin coin-three">🌳</span>
                <span class="leaf-card"></span>
              </div>
              <div class="tree-growth">
                <img src="assets/Seed.png" alt="Seed" class="tree-stage" />
                <img src="assets/Sapling.png" alt="Sapling" class="tree-stage" />
                <img src="assets/Plant.png" alt="Plant" class="tree-stage" />
                <img src="assets/Small tree.png" alt="Small Tree" class="tree-stage" />
                <img src="assets/Big tree.png" alt="Big Tree" class="tree-stage" />
              </div>
            </div>
            <div class="earning-copy">
              <small>Total Balance</small>
              <span id="waitingPoints">500</span>
              <strong>Green Points waiting in your wallet</strong>
            </div>
            <div class="wallet-stats" aria-label="Wallet preview stats">
              <span><strong>1,250</strong> Lifetime</span>
              <span><strong>150</strong> This Month</span>
              <span><strong>#23</strong> Rank</span>
            </div>
          </div>
          <div class="mission-tiles-row">
            <div class="mission-tile active">
              <strong>🌱 XP Points</strong>
              <span>Earn after every section</span>
            </div>
            <div class="mission-tile active">
              <strong>🌍 Awareness Score</strong>
              <span>Build your carbon literacy</span>
            </div>
            <div class="mission-tile active">
              <strong>🏆 Badge Unlocks</strong>
              <span>Collect 9 milestone badges</span>
            </div>
          </div>
        </div>
      </div>

      <div class="journey-preview">
        <article>
          <span>01</span>
          <strong>Profile</strong>
          <small>Lifestyle, city, household, pets</small>
        </article>
        <article>
          <span>02</span>
          <strong>Mobility</strong>
          <small>Commute, fuel, flights, travel days</small>
        </article>
        <article>
          <span>03</span>
          <strong>Home Energy</strong>
          <small>AC, appliances, cooking, tech</small>
        </article>
        <article>
          <span>04</span>
          <strong>Choices</strong>
          <small>Food, digital life, ESG, reflections</small>
        </article>
      </div>
    </section>

    <section class="quiz-stage" aria-live="polite" hidden>
      <div class="quiz-progress">
        <span id="questionCounter">Question 1 of 10</span>
        <div class="progress-track"><span id="progressBar"></span></div>
      </div>

      <article class="question-card">
        <p class="section-kicker" id="sectionName">Profile</p>
        <h1 id="questionTitle">How do you work?</h1>
        <p id="questionHelp">Let's understand your work setup.</p>

        <div id="answerArea" class="answer-area"></div>
      </article>

      <nav class="quiz-actions" aria-label="Quiz navigation">
        <button class="nav-button back-button" id="backButton" type="button">
          <span aria-hidden="true">&larr;</span>
          Back
        </button>
        <button class="nav-button next-button" id="nextButton" type="button" disabled>
          Next
          <span aria-hidden="true">&rarr;</span>
        </button>
      </nav>
    </section>

    <section class="reward-screen" id="rewardScreen" hidden aria-live="polite">
      <!-- Full screen rain canvas -->
      <canvas class="reward-rain-canvas" id="rewardRainCanvas" aria-hidden="true"></canvas>
      


      <div class="reward-card">
        <button class="close-card-button" id="quitFromRewardButton" type="button" aria-label="Close quiz">&times;</button>
        <p class="section-kicker" id="rewardSection">Section Completed</p>
        <h1>Section Completed!</h1>
        <div class="reward-metrics-grid">
          <!-- Green Points Tile -->
          <div class="flip-card">
            <div class="flip-card-inner">
              <div class="flip-card-front reward-tile">
                <span class="front-label">Green Points</span>
                <span class="tile-icon large">🌱</span>
              </div>
              <div class="flip-card-back reward-tile">
                <span id="rewardXpBack">50</span>
                <small>Points earned</small>
              </div>
            </div>
          </div>
          
          <!-- Awareness Score Tile -->
          <div class="flip-card">
            <div class="flip-card-inner">
              <div class="flip-card-front reward-tile">
                <span class="front-label">Awareness Score</span>
                <span class="tile-icon large">🌍</span>
              </div>
              <div class="flip-card-back reward-tile">
                <span id="rewardAwarenessBack">10</span>
                <small>Profile sharpened</small>
              </div>
            </div>
          </div>

          <!-- Badge Tile -->
          <div class="flip-card">
            <div class="flip-card-inner">
              <div class="flip-card-front reward-tile">
                <span class="front-label">Current Tier</span>
                <span class="tile-icon large">🏅</span>
              </div>
              <div class="flip-card-back reward-tile">
                <span id="rewardBadgeBack" style="font-size: clamp(1rem, 2.2vw, 1.3rem);">Brass Tier</span>
                <span class="tile-icon large" id="rewardBadgeIcon">🏅</span>
              </div>
            </div>
          </div>
        </div>
        <div class="reward-actions">
          <button class="nav-button next-button" id="continueButton" type="button">Continue &rarr;</button>
        </div>
      </div>
    </section>

    <section class="login-screen" id="loginScreen" hidden>
      <div class="login-card">
        <p class="section-kicker">Save Your Score</p>
        <h1>Tell us who you are.</h1>
        <p class="login-copy">Enter your name and email to save your progress and download your carbon score certificate.</p>
        <div class="user-details-form" style="display:flex; flex-direction:column; gap:16px; margin: 24px 0; text-align:left;">
          <label style="font-weight:600; display:flex; flex-direction:column; gap:8px;">
            Your Name
            <input type="text" id="userNameInput" placeholder="e.g. Jane Doe" style="padding:14px; border:1.5px solid var(--line); border-radius:12px; font-size:1rem; outline:none;" required>
          </label>
          <label style="font-weight:600; display:flex; flex-direction:column; gap:8px;">
            Email Address
            <input type="email" id="userEmailInput" placeholder="e.g. jane@example.com" style="padding:14px; border:1.5px solid var(--line); border-radius:12px; font-size:1rem; outline:none;" required>
          </label>
          <button class="nav-button next-button" id="saveUserDetailsButton" type="button" style="width:100%; justify-content:center; margin-top:8px;">Save & Download</button>
        </div>
        <div class="login-actions">
          <button class="nav-button back-button" id="backFromLoginButton" type="button">Go back</button>
          <a class="nav-button back-button" href="index.html">Home page</a>
        </div>
      </div>
    </section>

    <section class="feedback-screen" id="feedbackScreen" hidden>
      <div class="login-card feedback-card">
        <p class="section-kicker">Before you close</p>
        <h1>Close this quiz?</h1>
        <p class="login-copy">Share quick feedback so we can improve the quiz flow. Closing will reset this run and
          reopen the quiz landing page.</p>
        <label class="text-answer feedback-text">
          <span>What made you stop here?</span>
          <textarea id="closeFeedback" rows="4"
            placeholder="Example: Too many questions, unclear answer, just exploring..."></textarea>
        </label>
        <div class="login-actions">
          <button class="nav-button back-button" id="cancelCloseButton" type="button">Continue quiz</button>
          <button class="nav-button next-button" id="confirmCloseButton" type="button">Close and reset</button>
        </div>
      </div>
    </section>

    <section class="results-screen" id="resultsScreen" hidden>
      <div class="celebration-modal" id="celebrationModal" hidden>
        <div class="celebration-card">
          <p class="section-kicker">Quiz Completed</p>
          <h1>Great work!</h1>
          <p id="celebrationCopy">Your carbon score is ready.</p>
          <div class="celebration-score">
            <span id="celebrationScore">0</span>
            <small>kg CO2e / month</small>
          </div>
          <div class="celebration-actions">
            <button class="nav-button back-button" id="viewResultsButton" type="button">View result</button>
            <button class="nav-button next-button" id="downloadFromCelebrationButton" type="button">Download
              score</button>
          </div>
        </div>
      </div>
      <div class="result-hero">
        <p class="section-kicker">Your Green Score</p>
        <h1 id="resultTitle">You are building a greener routine.</h1>
        <div class="score-orbit">
          <span id="scoreValue">0</span>
          <small>kg CO2e / month</small>
        </div>
        <p id="resultCopy">Your footprint estimate is ready.</p>
      </div>

      <div class="result-grid">
        <article>
          <h2>Breakdown</h2>
          <div id="breakdownList"></div>
        </article>
        <article>
          <h2>Next best moves</h2>
          <ol id="recommendations"></ol>
        </article>
      </div>

      <div class="result-actions">
        <div class="icon-group">
          <a class="icon-button" href="index.html" data-tooltip="Home page" aria-label="Home page">
            <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          </a>
          <button class="icon-button" id="restartButton" type="button" data-tooltip="Restart quiz" aria-label="Restart quiz">
            <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><polyline points="23 20 23 14 17 14"></polyline><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"></path></svg>
          </button>
          <button class="icon-button" id="shareButton" type="button" data-tooltip="Share result" aria-label="Share result">
            <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
          </button>
        </div>
        <button class="nav-button next-button" id="downloadButton" type="button">Download score</button>
      </div>
    </section>
  </main>

  <script src="config.js"></script>
  <script src="api.js"></script>
  <script src="quiz.js"></script>
  <script src="leaf-rain.js"></script>
</body>

</html>